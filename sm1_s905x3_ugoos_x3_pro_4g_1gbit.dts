#include "sm1_s905x3_2g_1gbit.dts"

/{
  coreelec-dt-id = "sm1_s905x3_4g_1gbit";

  regulator-vbus_usb {
    compatible = "regulator-fixed";
                regulator-name = "vbus_usb";
                regulator-min-microvolt = <5000000>;
                regulator-max-microvolt = <5000000>;
                gpio = <&gpio GPIOH_5 GPIO_ACTIVE_HIGH>;
                enable-active-high;
                regulator-boot-on;
                regulator-always-on;
  };
  
  memory@00000000 {
    linux,usable-memory = <0x0 0x100000 0x0 0xf0800000>;
    /* 0xf5700000 used in stock android dtb changed
    to 0xf0800000 to fix some 4G generic devices
    not able to boot with the default value.*/
  };

  gpioleds {
    /* blue led */
  	remote_led {
  		label = "remote_led";
  		gpios = <&gpio_ao GPIOAO_10 GPIO_ACTIVE_HIGH>;
  		default-state = "off";
  	};

    /* red led */
  	sys_led {
        label="sys_led";
        gpios=<&gpio_ao GPIOAO_11 GPIO_ACTIVE_HIGH>;
        default-state ="on";
  	};
  };
};

&logo_reserved {
  alloc-ranges = <0x0 0xdf800000 0x0 0x800000>;
};

&meson_fb {
  logo_addr = "0xdf800000";
};

&drm_vpu {
  logo_addr = "0xdf800000";
};
