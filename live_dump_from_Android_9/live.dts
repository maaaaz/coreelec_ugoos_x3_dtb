		fip_size = <0x200000>;
		plat-num = <0x02>;
		bl_mode = <0x01>;
		fip_copies = <0x04>;
		pinctrl-names = "nand_rb_mod", "nand_norb_mod", "nand_cs_only";

		nandnormal {
			t_rhoh = <0x0f>;
			plane_mode = "twoplane";
			rb_detect = <0x01>;
			partition = <0x49>;
			t_rea = <0x14>;
			phandle = <0x48>;
			busy_pad = "rb0";
			part_num = <0x03>;
