			};
		};

		ao_ceca {
			phandle = <0xa1>;

			mux {
				groups = "cec_ao_a";
				function = "cec_ao";
			};
		};

		pwm_ao_d_pins1 {
			phandle = <0x9f>;

			mux {
				groups = "pwm_ao_d_5";
				function = "pwm_ao_d";
			};
