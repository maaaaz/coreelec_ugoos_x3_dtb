			phandle = <0xa9>;

			mux1 {
				output-low;
				groups = "GPIOX_4";
				function = "gpio_periphs";
			};

			mux {
				output-low;
				groups = "GPIOV_0";
				function = "gpio_periphs";
				bias-pull-up;
			};
		};

		emmc_conf_pull_up {
			phandle = <0x3a>;

			mux {
				drive-strength = <0x03>;
				groups = "emmc_nand_d7", "emmc_nand_d6", "emmc_nand_d5", "emmc_nand_d4", "emmc_nand_d3", "emmc_nand_d2", "emmc_nand_d1", "emmc_nand_d0", "emmc_clk", "emmc_cmd";
				function = "emmc";
				input-enable;
				bias-pull-up;
			};
