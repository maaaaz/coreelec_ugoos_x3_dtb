		bootloader {
			t_rhoh = <0x0f>;
			rb_detect = <0x01>;
			t_rea = <0x14>;
			phandle = <0x47>;
			busy_pad = "rb0";
			part_num = <0x00>;
			timming_mode = "mode5";
			chip_num = <0x01>;
			enable_pad = "ce0";
			bch_mode = "bch8_1k";
		};

		nand_partition {
			phandle = <0x49>;

			logo {
				offset = <0x00 0x00>;
				size = <0x00 0x200000>;
			};

			system {
				offset = <0x00 0x00>;
				size = <0x00 0x4000000>;
			};

			tpl {
				offset = <0x00 0x00>;
				size = <0x00 0x00>;
			};

			data {
				offset = <0xffffffff 0xffffffff>;
				size = <0x00 0x00>;
			};

			recovery {
				offset = <0x00 0x00>;
				size = <0x00 0x1000000>;
			};

			boot {
				offset = <0x00 0x00>;
				size = <0x00 0x1000000>;
			};
		};
	};

