/dts-v1/;

/ {
	compatible = "amlogic, g12a";
	model = "Amlogic";
	interrupt-parent = <0x01>;
	#address-cells = <0x01>;
	#size-cells = <0x01>;
	amlogic-dt-id = "sm1_X2CUBE_4g";

	codec_mm {
		compatible = "amlogic, codec, mm";
		dev_name = "codec_mm";
		status = "okay";
		memory-region = <0x68 0x69>;
	};

	codec_io {
		compatible = "amlogic, codec_io";
		ranges;
		status = "okay";
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		phandle = <0xf0>;

		io_efuse_base {
			reg = <0xff630000 0x2000>;
		};

		io_cbus_base {
			reg = <0xffd00000 0x100000>;
		};

		io_dmc_base {
			reg = <0xff638000 0x2000>;
		};

		io_vcbus_base {
			reg = <0xff900000 0x40000>;
		};

		io_hiubus_base {
			reg = <0xff63c000 0x2000>;
		};

		io_aobus_base {
			reg = <0xff800000 0x10000>;
		};

		io_dos_base {
			reg = <0xff620000 0x10000>;
		};
	};

	cpu_iomap {
		compatible = "amlogic, iomap";
		ranges;
		#address-cells = <0x01>;
		#size-cells = <0x01>;

		io_apb_base {
			reg = <0xffe01000 0x7f000>;
		};

		io_cbus_base {
			reg = <0xffd00000 0x26fff>;
		};

		io_vapb_base {
			reg = <0xff900000 0x50000>;
		};

		io_aobus_base {
			reg = <0xff800000 0xb000>;
		};

		io_hiu_base {
			reg = <0xff63c000 0x2000>;
		};
	};

	amlvideo2_1 {
		compatible = "amlogic, amlvideo2";
		amlvideo2_id = <0x01>;
		dev_name = "amlvideo2";
		cma_mode = <0x01>;
		status = "okay";
	};

	aml_dma {
		compatible = "amlogic,aml_txlx_dma";
		interrupts = <0x00 0xb4 0x01>;
		reg = <0xff63e000 0x48>;

		aml_sha {
			compatible = "amlogic,sha_dma";
			dev_name = "aml_sha_dma";
			status = "okay";
		};

		aml_aes {
			compatible = "amlogic,aes_g12a_dma";
			dev_name = "aml_aes_dma";
			status = "okay";
		};
	};

	vcodec_dec {
		compatible = "amlogic, vcodec-dec";
		dev_name = "aml-vcodec-dec";
		status = "okay";
	};

	bt-dev {
		compatible = "amlogic, bt-dev";
		dev_name = "bt-dev";
		status = "okay";
		gpio_hostwake = <0x14 0x55 0x00>;
		gpio_reset = <0x14 0x53 0x00>;
	};

	amvenc_avc {
		compatible = "amlogic, amvenc_avc";
		dev_name = "amvenc_avc";
		status = "okay";
		interrupts = <0x00 0x2d 0x01>;
		interrupt-names = "mailbox_2";
	};

	reserved-memory {
		ranges;
		#address-cells = <0x01>;
		#size-cells = <0x01>;

		linux,ion-dev {
			reusable;
			compatible = "shared-dma-pool";
			alignment = <0x400000>;
			alloc-ranges = <0x30000000 0x50000000>;
			size = <0x8000000>;
			phandle = <0x1b>;
		};

		ramoops@0x07400000 {
			compatible = "ramoops";
			record-size = <0x8000>;
			console-size = <0x8000>;
			ftrace-size = <0x40000>;
			reg = <0x7400000 0x100000>;
		};

		linux,meson-fb {
			reusable;
			compatible = "shared-dma-pool";
			alignment = <0x400000>;
			alloc-ranges = <0x7f800000 0x800000>;
			size = <0x800000>;
			phandle = <0x37>;
		};

		linux,ppmgr {
			compatible = "shared-dma-pool";
			size = <0x00>;
			phandle = <0x6b>;
		};

		linux,secos {
			compatible = "amlogic, aml_secos_memory";
			status = "disable";
			no-map;
			phandle = <0x105>;
			reg = <0x5300000 0x2000000>;
		};

		linux,di_cma {
			reusable;
			compatible = "shared-dma-pool";
			alignment = <0x400000>;
			size = <0x2800000>;
			phandle = <0x6c>;
		};

		linux,codec_mm_cma {
			reusable;
			compatible = "shared-dma-pool";
			alignment = <0x400000>;
			alloc-ranges = <0x30000000 0x50000000>;
			size = <0x13400000>;
			phandle = <0x68>;
			linux,contiguous-region;
		};

		linux,secmon {
			reusable;
			compatible = "shared-dma-pool";
			alignment = <0x400000>;
			alloc-ranges = <0x5000000 0x400000>;
			size = <0x400000>;
			phandle = <0x0f>;
		};

		linux,codec_mm_reserved {
			compatible = "amlogic, codec-mm-reserved";
			alignment = <0x100000>;
			size = <0x00>;
			phandle = <0x69>;
		};
	};

	galcore {
		compatible = "amlogic, galcore";
		clocks = <0x02 0xe8 0x02 0xe7>;
		nn_efuse = <0xff63003c 0x20>;
		dev_name = "galcore";
		reg-names = "NN_REG", "NN_SRAM", "NN_MEM0", "NN_MEM1", "NN_RESET", "NN_CLK";
		clock-names = "cts_vipnanoq_axi_clk_composite", "cts_vipnanoq_core_clk_composite";
		status = "okay";
		interrupts = <0x00 0xba 0x04>;
		reg = <0xff100000 0x800 0xff000000 0x400000 0xff63c118 0x00 0xff63c11c 0x00 0xffd01088 0x00 0xff63c1c8 0x00>;
		nn_power_version = <0x03>;
		interrupt-names = "galcore";
	};

	amlvecm {
		compatible = "amlogic, vecm";
		wb_en = <0x00>;
		dev_name = "aml_vecm";
		cm_en = <0x00>;
		status = "okay";
		gamma_en = <0x00>;
		tx_op_color_primary = <0x00>;
	};

	dummy {
		compatible = "amlogic, aml_dummy_codec";
		#sound-dai-cells = <0x00>;
		status = "okay";
		phandle = <0x83>;
	};

	vout {
		compatible = "amlogic, vout";
		dev_name = "vout";
		status = "okay";
	};

	dwc2_a@ff400000 {
		port-type = <0x02>;
		compatible = "amlogic, dwc2";
		port-config = <0x00>;
		clocks = <0x02 0x41 0x02 0x49>;
		port-speed = <0x00>;
		controller-type = <0x03>;
		clock-names = "usb_general", "usb1";
		clock-src = "usb0";
		status = "okay";
		interrupts = <0x00 0x1f 0x04>;
		port-id-mode = <0x00>;
		phandle = <0xc4>;
		phy-interface = <0x02>;
		device_name = "dwc2_a";
		phy-reg = <0xffe09000>;
		usb-fifo = <0x2d8>;
		reg = <0xff400000 0x40000>;
		cpu-type = "v2";
		port-id = <0x00>;
		port-dma = <0x00>;
		pl-periph-id = <0x00>;
		phy-reg-size = <0xa0>;
	};

	watchdog@0xffd0f0d0 {
		compatible = "amlogic, meson-wdt";
		clocks = <0x15>;
		clock-names = "xtal";
		reset_watchdog_time = <0x02>;
		shutdown_timeout = <0x0a>;
		status = "okay";
		suspend_timeout = <0x06>;
		default_timeout = <0x0a>;
		phandle = <0xc5>;
		firmware_timeout = <0x06>;
		reg = <0xffd0f0d0 0x10>;
		reset_watchdog_method = <0x01>;
	};

	p_tsensor@ff634800 {
		compatible = "amlogic, r1p1-tsensor";
		clocks = <0x02 0xd6>;
		cal_d = <0x24c3>;
		#thermal-sensor-cells = <0x01>;
		clock-names = "ts_comp";
		cal_b = <0x1a8>;
		rtemp = <0x1c138>;
		status = "okay";
		interrupts = <0x00 0x23 0x00>;
		phandle = <0x4c>;
		device_name = "meson-pthermal";
		reg = <0xff634800 0x50 0xff800268 0x04>;
		cal_type = <0x01>;
		cal_c = <0xc57>;
		cal_a = <0x144>;
	};

	cpufreq-meson {
		compatible = "amlogic, cpufreq-meson";
		status = "okay";
		pinctrl-0 = <0x8c>;
		pinctrl-names = "default";
	};

	audio_data {
		compatible = "amlogic, audio_data";
		query_licence_cmd = <0x82000050>;
		status = "okay";
		phandle = <0xc2>;
	};

	d_tsensor@ff634c00 {
		compatible = "amlogic, r1p1-tsensor";
		clocks = <0x02 0xd6>;
		cal_d = <0x24c3>;
		#thermal-sensor-cells = <0x01>;
		clock-names = "ts_comp";
		cal_b = <0x1a8>;
		rtemp = <0x1c138>;
		status = "okay";
		interrupts = <0x00 0x24 0x00>;
		phandle = <0x52>;
		device_name = "meson-dthermal";
		reg = <0xff634c00 0x50 0xff800230 0x04>;
		cal_type = <0x01>;
		cal_c = <0xc57>;
		cal_a = <0x144>;
	};

	defendkey {
		compatible = "amlogic, defendkey";
		status = "okay";
		mem_size = <0x00 0x100000>;
		phandle = <0xf7>;
		reg = <0xff630218 0x04>;
	};

	wifi_pwm_conf {
		phandle = <0x66>;

		pwm_channel2_conf {
			times = <0x0c>;
			duty-cycle = <0x3b92>;
			pwms = <0x67 0x02 0x7724 0x00>;
		};

		pwm_channel1_conf {
			times = <0x0a>;
			duty-cycle = <0x3ba6>;
			pwms = <0x67 0x00 0x774d 0x00>;
		};
	};

	wifi {
		pwm_config = <0x66>;
		compatible = "amlogic, aml_wifi";
		interrupt_pin = <0x14 0x49 0x00>;
		dev_name = "aml_wifi";
		status = "okay";
		dhd_static_buf;
		pinctrl-0 = <0x65>;
		power_on_pin = <0x14 0x48 0x00>;
		pinctrl-names = "default";
		irq_trigger_type = "GPIO_IRQ_LOW";
	};

	dmc_monitor {
		compatible = "amlogic, dmc_monitor";
		status = "okay";
		interrupts = <0x00 0x33 0x01>;
		reg_base = <0xff639000>;
	};

	meson-irblaster {
		compatible = "amlogic, meson_irblaster";
		status = "okay";
		interrupts = <0x00 0xc6 0x01>;
		phandle = <0xf2>;
		reg = <0xff80014c 0x10 0xff800040 0x04>;
		pinctrl-0 = <0x38>;
		pinctrl-names = "default";
	};

	meson-amvideom {
		compatible = "amlogic, amvideom";
		dev_name = "amvideom";
		status = "okay";
		interrupts = <0x00 0x03 0x01>;
		interrupt-names = "vsync";
	};

	aml_pm {
		compatible = "amlogic, pm";
		status = "okay";
		device_name = "aml_pm";
		debug_reg = <0xff8000a8>;
		exit_reg = <0xff80023c>;
	};

	serial@ffd24000 {
		compatible = "amlogic, meson-uart";
		clocks = <0x15 0x02 0x2e>;
		fifosize = <0x80>;
		clock-names = "clk_uart", "clk_gate";
		status = "okay";
		interrupts = <0x00 0x1a 0x01>;
		phandle = <0xe7>;
		reg = <0xffd24000 0x18>;
		pinctrl-0 = <0x2d>;
		pinctrl-names = "default";
	};

	cpu_ver_name {
		compatible = "amlogic, cpu-major-id-sm1";
	};

	linux,picdec {
		reusable;
		compatible = "shared-dma-pool";
		alignment = <0x00>;
		size = <0x00>;
		phandle = <0x6a>;
		linux,contiguous-region;
	};

	secmon {
		compatible = "amlogic, secmon";
		in_base_func = <0x82000020>;
		out_base_func = <0x82000021>;
		reserve_mem_size = <0x300000>;
		memory-region = <0x0f>;
	};

