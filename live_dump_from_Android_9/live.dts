		cpu@1 {
			compatible = "arm,cortex-a53", "arm,armv8";
			clocks = <0x02 0x17 0x02 0x16 0x02 0x00 0x02 0xf8 0x02 0xf7>;
			cpu-idle-states = <0x0c>;
			device_type = "cpu";
			clock-names = "core_clk", "low_freq_clk_parent", "high_freq_clk_parent", "dsu_clk", "dsu_pre_parent";
			voltage-tolerance = <0x00>;
			enable-method = "psci";
			cpu-supply = <0x0e>;
			phandle = <0x09>;
			operating-points-v2 = <0x0d>;
			reg = <0x01>;
			clock-latency = <0xc350>;
		};

		cpu-map {

			cluster0 {
				phandle = <0x92>;

				core0 {
