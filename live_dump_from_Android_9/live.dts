			};
		};

		ao_uart {
			phandle = <0x96>;

			mux {
				groups = "uart_ao_tx_a", "uart_ao_rx_a";
				function = "uart_ao_a";
			};
		};

		pwm_ao_a {
			phandle = <0x99>;

			mux {
				groups = "pwm_ao_a";
				function = "pwm_ao_a";
			};
		};

		ao-bank@ff800014 {
			reg-names = "mux", "gpio", "drive-strength";
