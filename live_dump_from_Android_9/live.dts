	ddr_bandwidth {
		compatible = "amlogic, ddr-bandwidth";
		status = "okay";
		interrupts = <0x00 0x34 0x01>;
		reg = <0xff638000 0x100 0xff638c00 0x100>;
		interrupt-names = "ddr_bandwidth";
	};

	arm_pmu {
		compatible = "arm,cortex-a15-pmu";
		max-wait-cnt = <0x2710>;
		cpumasks = <0x0f>;
		interrupts = <0x00 0x89 0x04>;
		reg = <0xff634680 0x04>;
		relax-timer-ns = <0x989680>;
	};

	soc {
		compatible = "simple-bus";
		ranges;
		#address-cells = <0x01>;
		#size-cells = <0x01>;

		aobus@ff800000 {
			compatible = "simple-bus";
			ranges = <0x00 0xff800000 0xb000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			phandle = <0xd4>;
			reg = <0xff800000 0xb000>;

			pwm@2000 {
				compatible = "amlogic,g12a-ao-pwm";
				clocks = <0x15 0x15 0x15 0x15>;
				clock-names = "clkin0", "clkin1", "clkin2", "clkin3";
				status = "okay";
				phandle = <0x4a>;
				reg = <0x2000 0x20>;
				#pwm-cells = <0x03>;
			};

			i2c@5000 {
				compatible = "amlogic,meson-g12a-i2c";
				clocks = <0x02 0x2a>;
				clock-names = "clk_i2c";
				status = "disabled";
				#address-cells = <0x01>;
				interrupts = <0x00 0xc3 0x01 0x00 0xc9 0x01>;
				#size-cells = <0x00>;
				phandle = <0xd7>;
				reg = <0x5000 0x20>;
			};

			clock-controller@0 {
				compatible = "amlogic,sm1-aoclkc";
				#reset-cells = <0x01>;
				#clock-cells = <0x01>;
				phandle = <0xd5>;
				reg = <0x00 0x3dc>;
			};

			pwm@7000 {
				compatible = "amlogic,g12a-ao-pwm";
				clocks = <0x15 0x15 0x15 0x15>;
				clock-names = "clkin0", "clkin1", "clkin2", "clkin3";
				status = "disabled";
				phandle = <0xd6>;
				reg = <0x7000 0x20>;
				#pwm-cells = <0x03>;
			};

			cpu_version {
				reg = <0x220 0x04>;
			};

			serial@4000 {
				compatible = "amlogic, meson-uart";
				clocks = <0x15>;
				fifosize = <0x40>;
				clock-names = "clk_uart";
				status = "disabled";
				interrupts = <0x00 0xc5 0x01>;
				phandle = <0xda>;
				reg = <0x4000 0x18>;
				pinctrl-0 = <0x1a>;
				pinctrl-names = "default";
			};

			i2c_slave@6000 {
				compatible = "amlogic, meson-i2c-slave";
				status = "disabled";
				interrupts = <0x00 0xc2 0x01>;
				phandle = <0xd8>;
				reg = <0x6000 0x20>;
				pinctrl-0 = <0x19>;
				pinctrl-names = "default";
			};

			serial@3000 {
				compatible = "amlogic, meson-uart";
				clocks = <0x15>;
				xtal_tick_en = <0x02>;
				fifosize = <0x40>;
				clock-names = "clk_uart";
				status = "okay";
				interrupts = <0x00 0xc1 0x01>;
