			};

			mux {
				groups = "GPIOC_0", "GPIOC_1", "GPIOC_2", "GPIOC_3", "GPIOC_5";
				function = "gpio_periphs";
				output-high;
			};
		};

		nand_cs {
			phandle = <0x46>;

			mux {
				groups = "nand_ce0";
				function = "nand";
			};
		};

		all_nand_pins {
			phandle = <0x45>;

			mux {
				groups = "emmc_nand_d0", "emmc_nand_d1", "emmc_nand_d2", "emmc_nand_d3", "emmc_nand_d4", "emmc_nand_d5", "emmc_nand_d6", "emmc_nand_d7", "nand_ce0", "nand_ale", "nand_cle", "nand_wen_clk", "nand_ren_wr", "nand_rb0";
				function = "nand";
				input-enable;
			};
		};

		tdmc_mclk {
			phandle = <0x22>;

			mux {
				groups = "mclk1_a";
				function = "mclk1";
			};
		};

		tdmin_a {
			phandle = <0x1e>;

			mux {
				groups = "tdma_din1";
				function = "tdma_in";
			};
		};

		sd_all_pins {
			phandle = <0x3c>;

			mux1 {
				drive-strength = <0x03>;
				groups = "sdcard_clk_c";
				function = "sdcard";
				bias-pull-up;
				output-high;
			};

			mux {
				drive-strength = <0x03>;
				groups = "sdcard_d0_c", "sdcard_d1_c", "sdcard_d2_c", "sdcard_d3_c", "sdcard_cmd_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
			};
		};

		i2c0_pins3 {
			phandle = <0xac>;

			mux {
				drive-strength = <0x02>;
				groups = "i2c0_sda_z7", "i2c0_sck_z8";
				function = "i2c0";
			};
		};

		pwm_d_pins1 {
			phandle = <0xb9>;

			mux {
				groups = "pwm_d_x3";
				function = "pwm_d";
			};
		};

		sd_all_pd_pins {
			phandle = <0x42>;

			mux {
				output-low;
				groups = "GPIOC_0", "GPIOC_1", "GPIOC_2", "GPIOC_3", "GPIOC_4", "GPIOC_5";
				function = "gpio_periphs";
				bias-pull-down;
			};
		};

		tdmout_c {
			phandle = <0x23>;

			mux {
				groups = "tdmc_sclk_a", "tdmc_fs_a", "tdmc_dout0_a";
				function = "tdmc_out";
			};
		};

		ee_ceca {
			phandle = <0x35>;

			mux {
				groups = "cec_ao_a_ee";
				function = "cec_ao_ee";
			};
		};

		spicc0_pins_x {
			phandle = <0xbd>;

			mux {
				drive-strength = <0x01>;
				groups = "spi0_mosi_x", "spi0_miso_x", "spi0_clk_x";
				function = "spi0";
			};
		};

		internal_eth_pins {
			phandle = <0xc0>;

			mux {
				groups = "eth_link_led", "eth_act_led";
				function = "eth";
			};
		};

		i2c0_pins1 {
			phandle = <0xaa>;

			mux {
				drive-strength = <0x02>;
				groups = "i2c0_sda_c", "i2c0_sck_c";
				function = "i2c0";
			};
		};

		sdio_x_en_pins {
			phandle = <0xa8>;

			mux {
				groups = "sdio_dummy";
				function = "sdio";
				bias-pull-up;
				output-high;
			};
		};

		hdmitx_ddc {
			phandle = <0x32>;

			mux {
				bias-disable;
				drive-strength = <0x03>;
				groups = "hdmitx_sda", "hdmitx_sck";
				function = "hdmitx";
			};
		};

		pwm_c_pins2 {
			phandle = <0xb7>;

			mux {
				groups = "pwm_c_x5";
				function = "pwm_c";
			};
		};

		sd_clk_cmd_pins {
			phandle = <0x3d>;

			mux1 {
				drive-strength = <0x03>;
				groups = "sdcard_clk_c";
				function = "sdcard";
				bias-pull-up;
				output-high;
			};

			mux {
				drive-strength = <0x03>;
				groups = "sdcard_cmd_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
			};
		};

		tdmb_mclk {
			phandle = <0x1f>;

			mux {
				drive-strength = <0x02>;
				groups = "mclk0_a";
				function = "mclk0";
			};
		};

		i2c3_pins1 {
			phandle = <0x34>;

			mux {
				drive-strength = <0x02>;
				groups = "i2c3_sda_h", "i2c3_sck_h";
				function = "i2c3";
			};
		};

		c_uart {
			phandle = <0x2f>;

			mux {
				groups = "uart_tx_c", "uart_rx_c";
				function = "uart_c";
			};
		};

		tdmout_a {
			phandle = <0x1d>;

			mux {
				groups = "tdma_sclk", "tdma_fs", "tdma_dout0";
				function = "tdma_out";
			};
		};

		pwm_f_pins2 {
			phandle = <0xbc>;

			mux {
				groups = "pwm_f_h";
				function = "pwm_f";
			};
		};

		sd_1bit_pins {
			phandle = <0x3e>;

			mux1 {
				drive-strength = <0x03>;
				groups = "sdcard_clk_c";
				function = "sdcard";
				bias-pull-up;
				output-high;
			};

			mux {
				drive-strength = <0x03>;
				groups = "sdcard_d0_c", "sdcard_cmd_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
			};
		};

		spicc0_pins_c {
			phandle = <0xbe>;

			mux {
				drive-strength = <0x01>;
				groups = "spi0_mosi_c", "spi0_miso_c", "spi0_ss0_c", "spi0_clk_c";
				function = "spi0";
			};
		};

		i2c2_pins2 {
			phandle = <0xb1>;

			mux {
				drive-strength = <0x02>;
				groups = "i2c2_sda_z", "i2c2_sck_z";
				function = "i2c2";
			};
		};

		b_uart {
			phandle = <0x2e>;

			mux {
				groups = "uart_tx_b", "uart_rx_b";
				function = "uart_b";
			};
		};

		pwm_b_pins1 {
			phandle = <0xb4>;

			mux {
				groups = "pwm_b_x7";
				function = "pwm_b";
			};
		};

		i2c1_pins3 {
			phandle = <0xaf>;

			mux {
				drive-strength = <0x02>;
				groups = "i2c1_sda_h6", "i2c1_sck_h7";
				function = "i2c1";
			};
		};

		sdio_all_pins {
			phandle = <0x43>;

			mux {
				drive-strength = <0x03>;
				groups = "sdio_d0", "sdio_d1", "sdio_d2", "sdio_d3", "sdio_clk", "sdio_cmd";
				function = "sdio";
				input-enable;
				bias-pull-up;
			};
		};

		sd_clr_noall_pins {
			phandle = <0xa5>;

			mux {
				groups = "GPIOC_0", "GPIOC_1", "GPIOC_4", "GPIOC_5";
				function = "gpio_periphs";
				output-high;
			};
		};

		spdifout_a_mute {
			phandle = <0x26>;

			mux {
				groups = "GPIOH_4";
				function = "gpio_periphs";
			};
		};

		sdio_x_clk_cmd_pins {
			phandle = <0xa6>;

			mux1 {
				drive-strength = <0x03>;
				groups = "GPIOX_4";
				function = "gpio_periphs";
				bias-pull-up;
				output-high;
			};

			mux {
				drive-strength = <0x03>;
				groups = "GPIOX_5";
				function = "gpio_periphs";
				input-enable;
				bias-pull-up;
			};
		};

		banks@ff6346c0 {
			reg-names = "mux", "pull", "pull-enable", "gpio", "drive-strength";
			gpio-controller;
			phandle = <0x14>;
			reg = <0xff6346c0 0x40 0xff6344e8 0x18 0xff634520 0x18 0xff634440 0x4c 0xff634740 0x1c>;
			#gpio-cells = <0x02>;
		};

		tdmin_b {
			phandle = <0x21>;

			mux {
				drive-strength = <0x02>;
				groups = "tdmb_din1";
				function = "tdmb_in";
			};
		};

		hdmitx_hpd {
			phandle = <0x31>;

			mux {
				bias-disable;
				groups = "hdmitx_hpd_in";
				function = "hdmitx";
			};
		};

		emmc_clk_cmd_pins {
			phandle = <0x39>;

			mux {
				drive-strength = <0x03>;
				groups = "emmc_clk", "emmc_cmd";
				function = "emmc";
				input-enable;
				bias-pull-up;
			};
		};

		i2c1_pins1 {
			phandle = <0xad>;

			mux {
				drive-strength = <0x02>;
				groups = "i2c1_sda_x", "i2c1_sck_x";
				function = "i2c1";
			};
		};

		a_uart {
			phandle = <0x2d>;

			mux {
				groups = "uart_tx_a", "uart_rx_a", "uart_cts_a", "uart_rts_a";
				function = "uart_a";
			};
		};

		hdmitx_hpd_gpio {
			phandle = <0x33>;

			mux {
				bias-disable;
				groups = "GPIOH_1";
				function = "gpio_periphs";
			};
		};
	};

	rtc {
		compatible = "amlogic, aml_vrtc";
		alarm_reg_addr = <0xff8000a8>;
		timer_e_addr = <0xffd0f188>;
		status = "okay";
		init_date = "2015/01/01";
	};

	serial@ffd22000 {
		compatible = "amlogic, meson-uart";
		clocks = <0x15 0x02 0x3c>;
		fifosize = <0x40>;
		clock-names = "clk_uart", "clk_gate";
		status = "disabled";
		interrupts = <0x00 0x5d 0x01>;
		phandle = <0xe9>;
		reg = <0xffd22000 0x18>;
		pinctrl-0 = <0x2f>;
		pinctrl-names = "default";
	};

	ge2d {
		compatible = "amlogic, ge2d-sm1";
		clocks = <0x02 0x95 0x02 0x3d 0x02 0x96>;
		dev_name = "ge2d";
		clock-names = "clk_vapb_0", "clk_ge2d", "clk_ge2d_gate";
		status = "okay";
		interrupts = <0x00 0x92 0x01>;
		reg = <0xff940000 0x10000>;
		interrupt-names = "ge2d";
	};

	emmc@ffe07000 {
		cap-mmc-highspeed;
		compatible = "amlogic, meson-mmc-sm1";
		clocks = <0x02 0x35 0x02 0x72 0x02 0x02 0x02 0x20 0x15>;
		cap-sd-highspeed;
		pinctrl-1 = <0x3a 0x3b>;
		clock-names = "core", "clkin0", "clkin1", "clkin2", "xtal";
		status = "okay";
		interrupts = <0x00 0xbf 0x01>;
		disable-wp;
		bus-width = <0x08>;
		phandle = <0xf3>;
		reg = <0xffe07000 0x800>;
		pinctrl-0 = <0x39>;
		non-removable;
		max-frequency = <0xbebc200>;
		pinctrl-names = "emmc_clk_cmd_pins", "emmc_all_pins";

		emmc {
			max_req_size = <0x20000>;
			caps2 = "MMC_CAP2_HS200";
			gpio_dat3 = <0x14 0x1d 0x00>;
			f_min = <0x61a80>;
			card_type = <0x01>;
			f_max = <0x8f0d180>;
			ocr_avail = <0x200080>;
			hw_reset = <0x14 0x26 0x00>;
			co_phase = <0x03>;
			tx_delay = <0x00>;
			pinname = "emmc";
			caps = "MMC_CAP_8_BIT_DATA", "MMC_CAP_MMC_HIGHSPEED", "MMC_CAP_SD_HIGHSPEED", "MMC_CAP_NONREMOVABLE", "MMC_CAP_HW_RESET", "MMC_CAP_ERASE", "MMC_CAP_CMD23", "MMC_CAP_DRIVER_TYPE_D";
		};
	};

	vout2 {
		compatible = "amlogic, vout2";
		clocks = <0x02 0xc4 0x02 0xc9>;
		dev_name = "vout";
		clock-names = "vpu_clkc0", "vpu_clkc";
		status = "okay";
	};
};
