		pwm_ao_c_hiz {
			phandle = <0x9e>;

			mux {
				groups = "pwm_ao_c_hiz_4";
				function = "pwm_ao_c";
			};
		};

		ao_i2c_pins2 {
			phandle = <0x98>;

			mux {
				drive-strength = <0x02>;
				groups = "i2c_ao_sck_e", "i2c_ao_sda_e";
				function = "i2c_ao";
